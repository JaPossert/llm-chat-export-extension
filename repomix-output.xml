/* Universal LLM Conversation Exporter - Popup Styles */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    font-size: 14px;
    line-height: 1.4;
    color: #333;
    background: #ffffff;
    width: 320px;
    min-height: 400px;
    display: flex;
    flex-direction: column;
}

.container {
    display: flex;
    flex-direction: column;
    min-height: 400px;
    padding: 16px;
    flex: 1;
}

/* Header */
.header {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    padding-bottom: 12px;
    padding-left: 6px;
    padding-right: 6px;
    border-bottom: 1px solid #e5e5e5;
}

.icon {
    width: 128px;
    height: 128px;
}

.header-links {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: #666;
    width: 100%;
}

/* Main Content */
.main {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

/* Platform Info */
.platform-info {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 12px;
}

.platform-indicator {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.platform-name {
    font-weight: 500;
    color: #333;
}

.platform-status {
    font-size: 12px;
    color: #28a745;
}

.platform-status.error {
    color: #C64E21;
}

.platform-status.warning {
    color: #ffc107;
}

/* Export Section */
.export-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
}

/* Export Options */
.export-options {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.option-group {
    display: flex;
    align-items: center;
}

.checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: 14px;
    color: #333;
}

.checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
}

/* Export Button Container */
.export-button-container {
    margin-top: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-direction: column;
    gap: 16px;
    flex: 1;
}

/* Export Button */
.export-button {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background: #C64E21;
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(229, 171, 70, 0.2);
    min-width: 180px;
}

.export-button:hover {
    background: #C64E21;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(229, 171, 70, 0.3);
}

.export-button:active {
    transform: translateY(0);
    box-shadow: 0 2px 6px rgba(229, 171, 70, 0.2);
}

.export-button:disabled {
    background: #9ca3af;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

/* Error Section */
.error-section {
    text-align: left;
    padding: 20px 0;
}

.error-message {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;
    margin-bottom: 16px;
    color: #C64E21;
    font-weight: 500;
}

.error-icon {
    font-size: 18px;
}

.supported-platforms {
    text-align: left;
    background: #f8f9fa;
    border-radius: 6px;
    padding: 12px;
}

.supported-title {
    font-weight: 500;
    margin-bottom: 8px;
    color: #333;
}

.platform-list {
    list-style: none;
    padding-left: 0;
}

.platform-list li {
    padding: 2px 0;
    color: #666;
    font-size: 13px;
}

.platform-list li:before {
    content: "\2022";
    color: #007bff;
    margin-right: 8px;
}





.version-info {
    font-weight: 500;
    color: #9ca3af;
}

/* Responsive adjustments */
@media (max-width: 350px) {
    body {
        width: 280px;
    }
    
    .container {
        padding: 12px;
    }
}
